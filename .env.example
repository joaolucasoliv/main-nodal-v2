# NODAL production deploy template.
# Put real values in Vercel Project Settings, not in committed files.

# Runtime
NODE_ENV=production
DATA_BACKEND=supabase
PORT=4173
NEXT_PUBLIC_APP_URL=https://your-nodal-domain.example
PUBLIC_BASE_URL=https://your-nodal-domain.example
COOKIE_SECURE=true
TRUST_PROXY=true

# Supabase public client config. Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
# Legacy projects may use this instead of NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-legacy-anon-key

# Supabase server-only credentials. Configure only in Vercel/server env.
SUPABASE_SECRET_KEY=<set-in-vercel-server-env>
# Legacy projects may use this instead of SUPABASE_SECRET_KEY.
# SUPABASE_SERVICE_ROLE_KEY=replace-with-legacy-service-role-key
# SUPABASE_JWT_SECRET is not needed by this app unless you add local JWT verification.
# SUPABASE_JWT_SECRET=replace-only-if-needed-server-side

# Stripe is optional. Uncomment all four server-only values when billing goes live.
PAYMENTS_MODE=preview
# STRIPE_SECRET_KEY=<set-in-vercel-server-env-when-live>
# STRIPE_WEBHOOK_SECRET=<set-in-vercel-server-env-when-live>
# STRIPE_PRICE_MONTHLY=price_replace_monthly
# STRIPE_PRICE_ANNUAL=price_replace_annual

# Public subscription labels shown in the UI. Keep these in sync with Stripe prices.
SUBSCRIPTION_PRICE_MONTHLY_LABEL=US$10
SUBSCRIPTION_MONTHLY_PERIOD=/ month
SUBSCRIPTION_PRICE_ANNUAL_LABEL=US$100
SUBSCRIPTION_ANNUAL_PERIOD=/ year
SUBSCRIPTION_ANNUAL_BADGE=2 months free

# Optional cache. Use rediss:// for remote Redis.
# REDIS_URL=rediss://default:password@redis.example.com:6380/0

# Optional global city autocomplete provider. Defaults to GeoDB Cities.
# For production scale, prefer a paid/owned GeoDB-compatible endpoint.
# CITY_SEARCH_URL=https://geodb-free-service.wirefreethought.com/v1/geo/cities
# CITY_SEARCH_CONTACT_EMAIL=ops@example.com
# CITY_SEARCH_USER_AGENT=NODAL city search/1.0 (https://your-nodal-domain.example)

# Local-only SQLite fallback. Do not use on Vercel production.
# DATA_BACKEND=sqlite
# DATABASE_PATH=./data/nodal.sqlite

# Optional local development seed. Do not configure in production.
# SEED_ADMIN_EMAIL=admin@nodal.local
# SEED_ADMIN_PASSWORD=change-me-locally
# SEED_ADMIN_NAME=NODAL Admin
